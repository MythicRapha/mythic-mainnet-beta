# Mythic L2 Website — Environment Variables
# Copy to .env.local and fill in production values

# L1 RPC endpoint for the bridge proxy (HTTPS required in production)
L1_RPC_URL=https://api.mainnet-beta.solana.com

# Supply oracle service URL
SUPPLY_ORACLE_URL=http://localhost:4002

# Bridge relayer service URL
RELAYER_URL=http://localhost:4003

# Block explorer API URL
EXPLORER_API=http://localhost:4000
